{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"paths": {
			"@shared/*": ["../shared/src/*"]
		}
	},
	"include": ["src/**/*.ts", "prisma.config.ts"]
}
